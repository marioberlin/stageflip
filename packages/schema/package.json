{
  "name": "@stageflip/schema",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./presets/node": {
      "types": "./dist/presets/node.d.ts",
      "import": "./dist/presets/node.js",
      "require": "./dist/presets/node.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts src/presets/node.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts src/presets/node.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "gray-matter": "4.0.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "fast-check": "4.7.0"
  },
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marioberlin/stageflip.git",
    "directory": "packages/schema"
  }
}
