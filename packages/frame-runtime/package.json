{
  "name": "@stageflip/frame-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./path": {
      "types": "./dist/path.d.ts",
      "import": "./dist/path.js",
      "require": "./dist/path.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/path.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts src/path.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "culori": "4.0.2",
    "flubber": "0.4.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/culori": "2.1.1",
    "@types/flubber": "0.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "fast-check": "3.23.2",
    "happy-dom": "20.9.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
