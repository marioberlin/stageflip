{
  "name": "@stageflip/auth-middleware",
  "version": "0.0.0",
  "type": "module",
  "description": "StageFlip auth middleware — resolvePrincipal + requireAuth + requireRole + api-key verify (T-262).",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/marioberlin/stageflip.git",
    "directory": "packages/auth-middleware"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run"
  },
  "dependencies": {
    "@stageflip/auth-schema": "workspace:^"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "vitest": "2.1.9"
  }
}
