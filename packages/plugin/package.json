{
  "name": "@stageflip/plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "StageFlip Claude-plugin bundler — packages skills + MCP config + OAuth provider into a `claude plugin install`-ready directory.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/marioberlin/stageflip.git",
    "directory": "packages/plugin"
  },
  "homepage": "https://stageflip.dev",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@stageflip/mcp-server": "workspace:^"
  },
  "devDependencies": {
    "vitest": "2.1.9"
  }
}
