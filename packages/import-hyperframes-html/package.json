{
  "name": "@stageflip/import-hyperframes-html",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run"
  },
  "dependencies": {
    "@stageflip/loss-flags": "workspace:^",
    "@stageflip/schema": "workspace:^",
    "parse5": "7.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "vitest": "2.1.9"
  }
}
