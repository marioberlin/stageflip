{
  "name": "frame-runtime-counter",
  "runtime": "frame-runtime",
  "kind": "counter",
  "description": "Frame-runtime port of SlideMotion's counter clip — animates 0 → target with ease-out-expo (T-131b.1).",
  "composition": { "width": 640, "height": 360, "fps": 30, "durationInFrames": 60 },
  "clip": {
    "from": 0,
    "durationInFrames": 60,
    "props": { "target": 1000, "prefix": "$", "suffix": "" }
  },
  "referenceFrames": [0, 30, 59],
  "thresholds": {
    "minPsnr": 34,
    "minSsim": 0.97,
    "maxFailingFrames": 0
  },
  "goldens": { "dir": "goldens/frame-runtime-counter" }
}
