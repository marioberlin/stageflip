{
  "name": "frame-runtime-line-chart-draw",
  "runtime": "frame-runtime",
  "kind": "line-chart-draw",
  "description": "Frame-runtime port of SlideMotion's line-chart-draw — SVG path stroke-dashoffset draw + staggered dots (T-131b.2).",
  "composition": { "width": 640, "height": 360, "fps": 30, "durationInFrames": 60 },
  "clip": {
    "from": 0,
    "durationInFrames": 60,
    "props": {
      "values": [10, 28, 22, 35, 30, 48, 42],
      "labels": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
      "title": "Daily Active Users",
      "showDots": true
    }
  },
  "referenceFrames": [0, 30, 59],
  "thresholds": {
    "minPsnr": 32,
    "minSsim": 0.95,
    "maxFailingFrames": 0
  },
  "goldens": { "dir": "goldens/frame-runtime-line-chart-draw" }
}
