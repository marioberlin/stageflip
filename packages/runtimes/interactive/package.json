{
  "name": "@stageflip/runtimes-interactive",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./contract-tests": {
      "types": "./dist/contract-tests/index.d.ts",
      "import": "./dist/contract-tests/index.js",
      "require": "./dist/contract-tests/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts src/contract-tests/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts src/contract-tests/index.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@stageflip/schema": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "2.1.9",
    "happy-dom": "20.9.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "vitest": "2.1.9"
  },
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marioberlin/stageflip.git",
    "directory": "packages/runtimes/interactive"
  }
}
