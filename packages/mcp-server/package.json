{
  "name": "@stageflip/mcp-server",
  "version": "0.0.0",
  "type": "module",
  "description": "StageFlip MCP server — wraps the engine's semantic-tool registry + OAuth → JWT session flow for the Model Context Protocol.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/marioberlin/stageflip.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://stageflip.dev",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@stageflip/engine": "workspace:^",
    "@stageflip/llm-abstraction": "workspace:^",
    "jose": "6.2.2"
  },
  "devDependencies": {
    "vitest": "2.1.9",
    "zod": "3.25.76"
  }
}
