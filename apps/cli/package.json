{
  "name": "@stageflip/cli",
  "version": "0.0.0",
  "type": "module",
  "description": "StageFlip CLI — command-line access to the motion platform (slides, video, display).",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/marioberlin/stageflip.git",
    "directory": "apps/cli"
  },
  "homepage": "https://stageflip.dev",
  "bin": {
    "stageflip": "./dist/bin/stageflip.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --clean && tsup src/bin/stageflip.ts --format esm --out-dir dist/bin",
    "dev": "tsup src/index.ts --dts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@stageflip/mcp-server": "workspace:^",
    "@stageflip/plugin": "workspace:^",
    "@stageflip/skills-sync": "workspace:^",
    "commander": "13.1.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "vitest": "2.1.9"
  }
}
