{
  "name": "@stageflip/app-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "StageFlip CLI — user manual §4 command surface (T-225).",
  "bin": {
    "stageflip": "./dist/bin/stageflip.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin/stageflip.ts --dts --format esm --clean",
    "dev": "tsup src/index.ts src/bin/stageflip.ts --dts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@stageflip/mcp-server": "workspace:^",
    "@stageflip/plugin": "workspace:^",
    "@stageflip/skills-sync": "workspace:^",
    "commander": "13.1.0"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "vitest": "2.1.9"
  }
}
