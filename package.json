{
  "name": "stageflip",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI-native motion platform. One engine, three products (slide, video, display).",
  "license": "BUSL-1.1",
  "author": "Mario Tiedemann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marioberlin/stageflip.git"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "e2e": "playwright test",
    "e2e:slide": "pnpm --filter @stageflip/app-slide e2e",
    "e2e:install": "playwright install --with-deps chromium",
    "check-licenses": "tsx scripts/check-licenses.ts",
    "check-remotion-imports": "tsx scripts/check-remotion-imports.ts",
    "check-skill-drift": "tsx scripts/check-skill-drift.ts",
    "check-determinism": "tsx scripts/check-determinism.ts",
    "check-preset-integrity": "tsx scripts/check-preset-integrity.ts",
    "invoke-type-design-consultant": "tsx scripts/invoke-type-design-consultant.ts",
    "generate-parity-fixture": "tsx scripts/generate-preset-parity-fixture.ts",
    "check-cluster-eligibility": "tsx scripts/check-cluster-eligibility.ts",
    "parity": "turbo run build --filter=@stageflip/parity-cli && node packages/parity-cli/bin/parity.js",
    "parity:prime": "turbo run build --filter=@stageflip/parity-cli && node packages/parity-cli/bin/parity.js prime",
    "size-limit": "turbo run build --filter=@stageflip/frame-runtime --filter=@stageflip/cdp-host-bundle --filter=@stageflip/export-pptx --filter=@stageflip/import-google-slides --filter=@stageflip/rasterize --filter=@stageflip/import-hyperframes-html --filter=@stageflip/export-google-slides && size-limit",
    "load:smoke": "k6 run --out json=tests/load/runs/smoke-$(date +%Y%m%dT%H%M%S).json tests/load/scenarios/api-mixed.js && k6 run --out json=tests/load/runs/smoke-render-$(date +%Y%m%dT%H%M%S).json tests/load/scenarios/render-submit.js && k6 run --out json=tests/load/runs/smoke-collab-$(date +%Y%m%dT%H%M%S).json tests/load/scenarios/collab-sync.js",
    "load:full": "STAGEFLIP_LOAD_PROFILE=full k6 run --out json=tests/load/runs/full-$(date +%Y%m%dT%H%M%S).json tests/load/scenarios/api-mixed.js && STAGEFLIP_LOAD_PROFILE=full k6 run --out json=tests/load/runs/full-render-$(date +%Y%m%dT%H%M%S).json tests/load/scenarios/render-submit.js && STAGEFLIP_LOAD_PROFILE=full k6 run --out json=tests/load/runs/full-collab-$(date +%Y%m%dT%H%M%S).json tests/load/scenarios/collab-sync.js",
    "load:seed": "tsx tests/load/cli/seed-cli.ts",
    "load:cleanup": "tsx tests/load/cli/cleanup-cli.ts",
    "skills-sync": "tsx scripts/sync-skills.ts",
    "skills-sync:check": "tsx scripts/sync-skills.ts --check",
    "gen:tool-skills": "tsx scripts/gen-tool-skills.ts",
    "gen:tool-skills:check": "tsx scripts/gen-tool-skills.ts --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "2.31.0",
    "@playwright/test": "1.59.1",
    "@size-limit/preset-big-lib": "11.2.0",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "2.1.9",
    "license-checker": "25.0.1",
    "size-limit": "11.2.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "turbo": "2.9.6",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  },
  "pnpm": {
    "ignoredOptionalDependencies": [
      "@img/sharp-darwin-arm64",
      "@img/sharp-darwin-x64",
      "@img/sharp-libvips-darwin-arm64",
      "@img/sharp-libvips-darwin-x64",
      "@img/sharp-libvips-linux-arm",
      "@img/sharp-libvips-linux-arm64",
      "@img/sharp-libvips-linux-x64",
      "@img/sharp-libvips-linuxmusl-arm64",
      "@img/sharp-libvips-linuxmusl-x64",
      "@img/sharp-linux-arm",
      "@img/sharp-linux-arm64",
      "@img/sharp-linux-x64",
      "@img/sharp-linuxmusl-arm64",
      "@img/sharp-linuxmusl-x64",
      "@img/sharp-win32-arm64",
      "@img/sharp-win32-x64",
      "sharp"
    ]
  }
}
