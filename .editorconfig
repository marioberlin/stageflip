# .editorconfig — baseline rules for editors that don't read biome.json.
# Biome is the authority on TS/JS/JSON formatting; this file keeps other file
# types aligned.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
